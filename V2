#!/data/data/com.termux/files/usr/bin/bash
# ============================================================
#   ROBLOX AUTO-REJOIN TOOL v2 - TERMUX ROOT
#   Phát hiện: process chết | kẹt Home Roblox | màn đen/treo
# ============================================================

# ─── Màu sắc ────────────────────────────────────────────────
RED='\033[0;31m';    GREEN='\033[0;32m';  YELLOW='\033[1;33m'
CYAN='\033[0;36m';   BLUE='\033[0;34m';   MAGENTA='\033[0;35m'
WHITE='\033[1;37m';  BOLD='\033[1m';      RESET='\033[0m'

# ─── Biến cấu hình ──────────────────────────────────────────
ROBLOX_PKG=""
PLACE_ID=""
DELAY_CHECK=5          # Giây giữa mỗi lần kiểm tra
DELAY_REJOIN=10        # Giây chờ sau khi mở Roblox
DELAY_LOADING=30       # Giây chờ loading game lần đầu
BLACK_SCREEN_TIMEOUT=25  # Giây tối đa màn đen trước khi coi là treo
HOME_STUCK_TIMEOUT=20    # Giây tối đa ở Home Roblox trước khi rejoin

# ─── Biến trạng thái ────────────────────────────────────────
IS_RUNNING=false
LOG_FILE="$HOME/roblox_rejoin.log"
REJOIN_COUNT=0
LAST_STATE=""
STATE_SINCE=0          # Epoch khi vào trạng thái hiện tại
LAST_GAME_ACTIVITY=""  # Activity lần cuối biết đang trong game
FIRST_JOIN_DONE=false
TMP_SCREEN="/data/local/tmp/rbx_check.png"

# ─── Package Roblox phổ biến ────────────────────────────────
ROBLOX_PACKAGES=(
    "com.roblox.client"
    "com.roblox.robloxmobile"
    "com.roblox.client.beta"
)

# ─── Tiện ích ────────────────────────────────────────────────

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"; }

now() { date +%s; }

elapsed_since() { echo $(( $(now) - $1 )); }

print_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ██████╗  ██████╗ ██████╗ ██╗      ██████╗ ██╗  ██╗"
    echo "  ██╔══██╗██╔═══██╗██╔══██╗██║     ██╔═══██╗╚██╗██╔╝"
    echo "  ██████╔╝██║   ██║██████╔╝██║     ██║   ██║ ╚███╔╝ "
    echo "  ██╔══██╗██║   ██║██╔══██╗██║     ██║   ██║ ██╔██╗ "
    echo "  ██║  ██║╚██████╔╝██████╔╝███████╗╚██████╔╝██╔╝ ██╗"
    echo "  ╚═╝  ╚═╝ ╚═════╝ ╚═════╝ ╚══════╝ ╚═════╝ ╚═╝  ╚═╝"
    echo -e "${RESET}${MAGENTA}${BOLD}        ⚡ AUTO REJOIN v2 - SMART DETECT ⚡${RESET}"
    echo -e "${WHITE}  ────────────────────────────────────────────────────${RESET}"
    echo -e "${YELLOW}  Package : ${WHITE}${ROBLOX_PKG:-Chưa nhận diện}${RESET}"
    echo -e "${YELLOW}  Place ID: ${WHITE}${PLACE_ID:-Chưa thiết lập}${RESET}"
    local state_color="${RED}"
    [ "$IS_RUNNING" = true ] && state_color="${GREEN}"
    echo -e "${YELLOW}  Trạng thái: ${state_color}$([ "$IS_RUNNING" = true ] && echo "ĐANG CHẠY ✓" || echo "DỪNG ✗")${RESET}"
    echo -e "${YELLOW}  Đã rejoin: ${WHITE}${REJOIN_COUNT} lần${RESET}"
    echo -e "${WHITE}  ────────────────────────────────────────────────────${RESET}"
    echo ""
}

# ─── Kiểm tra root ──────────────────────────────────────────

check_root() {
    if ! su -c "echo ok" > /dev/null 2>&1; then
        echo -e "${RED}[LỖI] Máy chưa root hoặc Termux chưa được cấp quyền su!${RESET}"
        exit 1
    fi
}

# ─── Nhận diện Roblox ───────────────────────────────────────

auto_detect_roblox() {
    echo -e "${CYAN}[*] Đang nhận diện Roblox...${RESET}"
    for pkg in "${ROBLOX_PACKAGES[@]}"; do
        if su -c "pm list packages 2>/dev/null" | grep -q "$pkg"; then
            ROBLOX_PKG="$pkg"
            echo -e "${GREEN}[✓] Tìm thấy: ${WHITE}$ROBLOX_PKG${RESET}"
            log "Nhận diện Roblox: $ROBLOX_PKG"
            sleep 1
            return
        fi
    done
    echo -e "${RED}[✗] Không tìm thấy Roblox tự động.${RESET}"
    echo -ne "${YELLOW}Nhập package name thủ công: ${RESET}"
    read -r ROBLOX_PKG
    [ -z "$ROBLOX_PKG" ] && echo -e "${RED}Không có package, thoát.${RESET}" && exit 1
    sleep 1
}

# ─── Kiểm tra process ───────────────────────────────────────

is_roblox_running() {
    su -c "pidof '$ROBLOX_PKG'" > /dev/null 2>&1 || \
    su -c "ps -A 2>/dev/null | grep -q '$ROBLOX_PKG'"
}

# ─── Lấy activity đang focus của Roblox ─────────────────────

get_current_focus() {
    # Trả về dòng mCurrentFocus / mFocusedApp từ dumpsys window
    su -c "dumpsys window windows 2>/dev/null" \
        | grep -E "mCurrentFocus|mFocusedApp" \
        | head -2
}

is_roblox_foreground() {
    get_current_focus | grep -qi "$ROBLOX_PKG"
}

get_roblox_resumed_activity() {
    # Lấy tên Activity đang resumed (VD: com.roblox.client/.ActivityFoo)
    su -c "dumpsys activity activities 2>/dev/null" \
        | grep -i "mResumedActivity" \
        | grep -i "$ROBLOX_PKG" \
        | head -1 \
        | sed 's/.*{[^ ]* [^ ]* \([^ ]*\).*/\1/'
}

# ─── Phát hiện màn hình đen / treo ──────────────────────────
# Dùng screencap (root) → lấy kích thước file PNG nén
# Màn đen hoàn toàn → file PNG rất nhỏ (<30KB sau nén)
# Màn hình game bình thường → file lớn hơn nhiều

check_black_screen() {
    su -c "screencap -p '$TMP_SCREEN'" > /dev/null 2>&1
    if [ ! -f "$TMP_SCREEN" ]; then
        # screencap thất bại, không kết luận
        return 1
    fi
    local fsize
    fsize=$(wc -c < "$TMP_SCREEN" 2>/dev/null || echo 999999)
    su -c "rm -f '$TMP_SCREEN'" > /dev/null 2>&1

    # Nếu file PNG < 30KB thì màn hình gần như đen/trắng hoàn toàn
    if [ "$fsize" -lt 30720 ]; then
        return 0  # là màn đen
    fi
    return 1
}

# ─── Phát hiện trạng thái Roblox ────────────────────────────
# Trả về: DEAD | BACKGROUND | HOME | LOADING | GAME | BLACK | FROZEN

detect_state() {
    # 1. Process chết?
    if ! is_roblox_running; then
        echo "DEAD"
        return
    fi

    # 2. Roblox không ở foreground (đang chạy nền)
    if ! is_roblox_foreground; then
        echo "BACKGROUND"
        return
    fi

    # 3. Roblox ở foreground — lấy activity
    local activity
    activity=$(get_roblox_resumed_activity)

    # 4. Kiểm tra màn đen (chỉ khi cần, tốn 1-2s)
    if check_black_screen; then
        echo "BLACK"
        return
    fi

    # 5. Phân tích tên activity
    # Activity Home/Lobby Roblox thường chứa các từ khoá sau:
    if echo "$activity" | grep -qiE \
        "MainActivity|AppShell|HomeActivity|SplashActivity|LoginActivity|\
         StartupActivity|LaunchActivity|BootActivity|Hub|Portal|LandingActivity"; then
        echo "HOME"
        return
    fi

    # 6. Nếu activity giống activity game đã biết → IN GAME
    if [ -n "$LAST_GAME_ACTIVITY" ] && [ "$activity" = "$LAST_GAME_ACTIVITY" ]; then
        echo "GAME"
        return
    fi

    # 7. Activity không rõ → có thể đang loading hoặc game
    # Nếu chưa từng vào game → LOADING
    if [ "$FIRST_JOIN_DONE" = false ]; then
        echo "LOADING"
        return
    fi

    # 8. Activity thay đổi so với game activity đã biết → về HOME/kẹt
    if [ -n "$LAST_GAME_ACTIVITY" ] && [ "$activity" != "$LAST_GAME_ACTIVITY" ]; then
        echo "HOME"
        return
    fi

    # 9. Mặc định: coi là đang loading
    echo "LOADING"
}

# ─── Hành động rejoin ────────────────────────────────────────

send_join_intent() {
    # Gửi deep link vào game, KHÔNG kill Roblox nếu đang chạy
    su -c "am start -a android.intent.action.VIEW \
        -d 'roblox://placeId=${PLACE_ID}' \
        '${ROBLOX_PKG}'" > /dev/null 2>&1

    if [ $? -ne 0 ]; then
        # Fallback: am start -p rồi gửi intent
        su -c "am start -p '${ROBLOX_PKG}'" > /dev/null 2>&1
        sleep 2
        su -c "am start -a android.intent.action.VIEW \
            -d 'roblox://placeId=${PLACE_ID}'" > /dev/null 2>&1
    fi
}

force_stop_and_rejoin() {
    echo -e "${YELLOW}  → Force stop Roblox...${RESET}"
    su -c "am force-stop '${ROBLOX_PKG}'" > /dev/null 2>&1
    sleep 3
    FIRST_JOIN_DONE=false
    LAST_GAME_ACTIVITY=""
    send_join_intent
}

do_rejoin() {
    local reason="$1"
    REJOIN_COUNT=$((REJOIN_COUNT + 1))
    log "=== REJOIN #${REJOIN_COUNT} | Lý do: ${reason} | PlaceID=${PLACE_ID} ==="
    echo -e "${MAGENTA}[REJOIN #${REJOIN_COUNT}] Lý do: ${reason}${RESET}"
}

# ─── VÒNG LẶP CHÍNH ─────────────────────────────────────────

start_rejoin_loop() {
    if [ -z "$PLACE_ID" ]; then
        echo -e "${RED}[!] Chưa thiết lập Place ID!${RESET}"; sleep 2; return
    fi
    if [ -z "$ROBLOX_PKG" ]; then
        echo -e "${RED}[!] Chưa nhận diện package Roblox!${RESET}"; sleep 2; return
    fi

    IS_RUNNING=true
    REJOIN_COUNT=0
    FIRST_JOIN_DONE=false
    LAST_GAME_ACTIVITY=""
    LAST_STATE=""
    STATE_SINCE=$(now)

    echo ""
    echo -e "${GREEN}${BOLD}[✓] Bắt đầu Auto Rejoin Loop!${RESET}"
    echo -e "  Place ID : ${CYAN}${PLACE_ID}${RESET}"
    echo -e "  Package  : ${CYAN}${ROBLOX_PKG}${RESET}"
    echo -e "  Kiểm tra : mỗi ${CYAN}${DELAY_CHECK}s${RESET}"
    echo -e "${YELLOW}  Nhấn Ctrl+C để dừng và quay lại menu${RESET}"
    echo ""
    log "=== LOOP BẮT ĐẦU | PlaceID=${PLACE_ID} | Pkg=${ROBLOX_PKG} ==="

    # Lần đầu: mở game ngay
    echo -e "${CYAN}[INIT] Mở Roblox game lần đầu...${RESET}"
    force_stop_and_rejoin
    echo -e "${CYAN}[INIT] Chờ ${DELAY_LOADING}s để game tải...${RESET}"
    sleep "$DELAY_LOADING"

    while true; do
        sleep "$DELAY_CHECK"
        local ts state elapsed
        ts=$(date '+%H:%M:%S')
        state=$(detect_state)
        elapsed=$(elapsed_since "$STATE_SINCE")

        # Cập nhật thời điểm đổi trạng thái
        if [ "$state" != "$LAST_STATE" ]; then
            STATE_SINCE=$(now)
            elapsed=0
            log "Trạng thái đổi: ${LAST_STATE} → ${state}"
        fi
        LAST_STATE="$state"

        case "$state" in

            GAME)
                # Đang chơi game bình thường
                FIRST_JOIN_DONE=true
                # Lưu lại activity game để phát hiện khi rời
                local act
                act=$(get_roblox_resumed_activity)
                [ -n "$act" ] && LAST_GAME_ACTIVITY="$act"
                echo -e "${GREEN}[${ts}] ✓ TRONG GAME | Rejoin: ${REJOIN_COUNT}x | Activity: ${act:-?}${RESET}"
                ;;

            LOADING)
                # Đang loading — chờ, không làm gì
                echo -e "${CYAN}[${ts}] ⏳ LOADING... (${elapsed}s)${RESET}"
                # Nếu loading quá lâu (3 phút) thì force restart
                if [ "$elapsed" -gt 180 ]; then
                    echo -e "${RED}[${ts}] ⚠ Loading quá lâu (${elapsed}s)! Force restart...${RESET}"
                    do_rejoin "Loading quá lâu (${elapsed}s)"
                    force_stop_and_rejoin
                    echo -e "${CYAN}Chờ ${DELAY_LOADING}s...${RESET}"
                    sleep "$DELAY_LOADING"
                    STATE_SINCE=$(now)
                fi
                ;;

            HOME)
                # Kẹt ở Home Roblox — chờ HOME_STUCK_TIMEOUT rồi gửi lại intent
                echo -e "${YELLOW}[${ts}] 🏠 KẸT HOME ROBLOX (${elapsed}s/${HOME_STUCK_TIMEOUT}s)${RESET}"
                if [ "$elapsed" -ge "$HOME_STUCK_TIMEOUT" ]; then
                    do_rejoin "Kẹt Home Roblox (${elapsed}s)"
                    echo -e "${CYAN}  → Gửi lại lệnh vào game (không kill)...${RESET}"
                    send_join_intent
                    echo -e "${CYAN}  → Chờ ${DELAY_REJOIN}s...${RESET}"
                    sleep "$DELAY_REJOIN"
                    STATE_SINCE=$(now)
                    LAST_STATE=""

                    # Nếu vẫn còn ở HOME sau khi gửi intent 2 lần, force stop
                    sleep "$DELAY_CHECK"
                    local recheck
                    recheck=$(detect_state)
                    if [ "$recheck" = "HOME" ]; then
                        echo -e "${RED}  → Vẫn kẹt HOME! Force stop + rejoin...${RESET}"
                        log "Vẫn kẹt HOME sau intent, force stop"
                        force_stop_and_rejoin
                        echo -e "${CYAN}  → Chờ ${DELAY_LOADING}s...${RESET}"
                        sleep "$DELAY_LOADING"
                        STATE_SINCE=$(now)
                        LAST_STATE=""
                    fi
                fi
                ;;

            BLACK)
                # Màn hình đen — chờ BLACK_SCREEN_TIMEOUT rồi force restart
                echo -e "${RED}[${ts}] ⬛ MÀN HÌNH ĐEN/TREO (${elapsed}s/${BLACK_SCREEN_TIMEOUT}s)${RESET}"
                if [ "$elapsed" -ge "$BLACK_SCREEN_TIMEOUT" ]; then
                    do_rejoin "Màn hình đen (${elapsed}s)"
                    echo -e "${RED}  → Force stop + rejoin vì màn đen quá lâu...${RESET}"
                    log "Màn đen quá lâu: force stop"
                    force_stop_and_rejoin
                    echo -e "${CYAN}  → Chờ ${DELAY_LOADING}s...${RESET}"
                    sleep "$DELAY_LOADING"
                    STATE_SINCE=$(now)
                    LAST_STATE=""
                fi
                ;;

            DEAD)
                # Process Roblox chết hoàn toàn
                echo -e "${RED}[${ts}] 💀 ROBLOX CHẾT! Đang rejoin...${RESET}"
                do_rejoin "Process chết"
                force_stop_and_rejoin
                echo -e "${CYAN}  → Chờ ${DELAY_LOADING}s game tải...${RESET}"
                sleep "$DELAY_LOADING"
                STATE_SINCE=$(now)
                LAST_STATE=""
                ;;

            BACKGROUND)
                # Roblox chạy nền, bị ứng dụng khác che
                echo -e "${BLUE}[${ts}] 📲 Roblox chạy nền (${elapsed}s)${RESET}"
                # Đưa Roblox lên foreground
                if [ "$elapsed" -ge 10 ]; then
                    echo -e "${CYAN}  → Đưa Roblox lên foreground...${RESET}"
                    su -c "am start -p '${ROBLOX_PKG}'" > /dev/null 2>&1
                    sleep 3
                    STATE_SINCE=$(now)
                    LAST_STATE=""
                fi
                ;;

            *)
                echo -e "${YELLOW}[${ts}] ? Trạng thái không xác định: '${state}'${RESET}"
                ;;
        esac
    done

    IS_RUNNING=false
}

# ─── MENU CÀI ĐẶT ───────────────────────────────────────────

menu_settings() {
    while true; do
        print_banner
        echo -e "  ${BOLD}${WHITE}⚙  CÀI ĐẶT${RESET}"
        echo ""
        echo -e "  ${CYAN}1.${RESET} Place ID          : ${YELLOW}${PLACE_ID:-Chưa đặt}${RESET}"
        echo -e "  ${CYAN}2.${RESET} Check mỗi (s)     : ${YELLOW}${DELAY_CHECK}s${RESET}"
        echo -e "  ${CYAN}3.${RESET} Chờ rejoin (s)    : ${YELLOW}${DELAY_REJOIN}s${RESET}"
        echo -e "  ${CYAN}4.${RESET} Timeout loading   : ${YELLOW}${DELAY_LOADING}s${RESET}"
        echo -e "  ${CYAN}5.${RESET} Timeout màn đen   : ${YELLOW}${BLACK_SCREEN_TIMEOUT}s${RESET}"
        echo -e "  ${CYAN}6.${RESET} Timeout Home kẹt  : ${YELLOW}${HOME_STUCK_TIMEOUT}s${RESET}"
        echo -e "  ${CYAN}7.${RESET} Nhận diện lại Roblox"
        echo -e "  ${CYAN}8.${RESET} Đặt package thủ công"
        echo -e "  ${CYAN}0.${RESET} Quay lại"
        echo ""
        read -rp "$(echo -e "${WHITE}  Chọn: ${RESET}")" opt
        case $opt in
            1)
                echo -ne "${YELLOW}  Nhập Place ID (chỉ số): ${RESET}"
                read -r v
                if [[ "$v" =~ ^[0-9]+$ ]]; then
                    PLACE_ID="$v"
                    echo -e "${GREEN}  [✓] Place ID: $PLACE_ID${RESET}"
                else
                    echo -e "${RED}  [!] Phải là số!${RESET}"
                fi
                sleep 1 ;;
            2)
                echo -ne "${YELLOW}  Check mỗi X giây (>=2): ${RESET}"
                read -r v
                [[ "$v" =~ ^[0-9]+$ ]] && [ "$v" -ge 2 ] && DELAY_CHECK="$v" && echo -e "${GREEN}  [✓] ${DELAY_CHECK}s${RESET}" || echo -e "${RED}  [!] Tối thiểu 2s${RESET}"
                sleep 1 ;;
            3)
                echo -ne "${YELLOW}  Chờ rejoin X giây (>=3): ${RESET}"
                read -r v
                [[ "$v" =~ ^[0-9]+$ ]] && [ "$v" -ge 3 ] && DELAY_REJOIN="$v" && echo -e "${GREEN}  [✓] ${DELAY_REJOIN}s${RESET}" || echo -e "${RED}  [!] Tối thiểu 3s${RESET}"
                sleep 1 ;;
            4)
                echo -ne "${YELLOW}  Timeout loading (>=15s): ${RESET}"
                read -r v
                [[ "$v" =~ ^[0-9]+$ ]] && [ "$v" -ge 15 ] && DELAY_LOADING="$v" && echo -e "${GREEN}  [✓] ${DELAY_LOADING}s${RESET}" || echo -e "${RED}  [!] Tối thiểu 15s${RESET}"
                sleep 1 ;;
            5)
                echo -ne "${YELLOW}  Timeout màn đen (>=10s): ${RESET}"
                read -r v
                [[ "$v" =~ ^[0-9]+$ ]] && [ "$v" -ge 10 ] && BLACK_SCREEN_TIMEOUT="$v" && echo -e "${GREEN}  [✓] ${BLACK_SCREEN_TIMEOUT}s${RESET}" || echo -e "${RED}  [!] Tối thiểu 10s${RESET}"
                sleep 1 ;;
            6)
                echo -ne "${YELLOW}  Timeout Home kẹt (>=10s): ${RESET}"
                read -r v
                [[ "$v" =~ ^[0-9]+$ ]] && [ "$v" -ge 10 ] && HOME_STUCK_TIMEOUT="$v" && echo -e "${GREEN}  [✓] ${HOME_STUCK_TIMEOUT}s${RESET}" || echo -e "${RED}  [!] Tối thiểu 10s${RESET}"
                sleep 1 ;;
            7) auto_detect_roblox ;;
            8)
                echo -ne "${YELLOW}  Package (vd: com.roblox.client): ${RESET}"
                read -r v
                [ -n "$v" ] && ROBLOX_PKG="$v" && echo -e "${GREEN}  [✓] $ROBLOX_PKG${RESET}"
                sleep 1 ;;
            0) return ;;
        esac
    done
}

# ─── MENU TEST ───────────────────────────────────────────────

menu_test() {
    print_banner
    echo -e "  ${BOLD}${WHITE}🔧 KIỂM TRA & TEST${RESET}"
    echo ""
    echo -e "  ${CYAN}1.${RESET} Phát hiện trạng thái ngay bây giờ"
    echo -e "  ${CYAN}2.${RESET} Kiểm tra màn hình đen"
    echo -e "  ${CYAN}3.${RESET} Mở game (gửi intent 1 lần)"
    echo -e "  ${CYAN}4.${RESET} Force stop Roblox"
    echo -e "  ${CYAN}5.${RESET} Xem foreground activity"
    echo -e "  ${CYAN}6.${RESET} Xem process Roblox"
    echo -e "  ${CYAN}0.${RESET} Quay lại"
    echo ""
    read -rp "$(echo -e "${WHITE}  Chọn: ${RESET}")" topt
    case $topt in
        1)
            echo ""
            local s; s=$(detect_state)
            case $s in
                GAME)       echo -e "${GREEN}  → TRONG GAME ✓${RESET}" ;;
                HOME)       echo -e "${YELLOW}  → KẸT HOME ROBLOX${RESET}" ;;
                LOADING)    echo -e "${CYAN}  → ĐANG LOADING...${RESET}" ;;
                BLACK)      echo -e "${RED}  → MÀN HÌNH ĐEN${RESET}" ;;
                DEAD)       echo -e "${RED}  → ROBLOX KHÔNG CHẠY${RESET}" ;;
                BACKGROUND) echo -e "${BLUE}  → ROBLOX CHẠY NỀN${RESET}" ;;
                *)          echo -e "${YELLOW}  → ${s}${RESET}" ;;
            esac
            sleep 3 ;;
        2)
            echo ""
            if check_black_screen; then
                echo -e "${RED}  → MÀN HÌNH ĐEN phát hiện!${RESET}"
            else
                echo -e "${GREEN}  → Màn hình bình thường (không đen)${RESET}"
            fi
            sleep 3 ;;
        3)
            echo ""
            send_join_intent
            echo -e "${GREEN}  [✓] Đã gửi intent vào game!${RESET}"
            sleep 2 ;;
        4)
            echo ""
            su -c "am force-stop '$ROBLOX_PKG'" > /dev/null 2>&1
            echo -e "${GREEN}  [✓] Đã force stop!${RESET}"
            sleep 2 ;;
        5)
            echo ""
            echo -e "${CYAN}  Foreground activity:${RESET}"
            get_current_focus
            echo ""
            echo -e "${CYAN}  Resumed activity:${RESET}"
            get_roblox_resumed_activity
            echo ""
            sleep 4 ;;
        6)
            echo ""
            echo -e "${CYAN}  Process Roblox:${RESET}"
            su -c "ps -A 2>/dev/null | grep -i roblox" || echo -e "${YELLOW}  (không có)${RESET}"
            sleep 3 ;;
    esac
}

# ─── MENU LOG ────────────────────────────────────────────────

menu_log() {
    print_banner
    echo -e "  ${BOLD}${WHITE}📋 LOG: $LOG_FILE${RESET}"
    echo ""
    if [ -f "$LOG_FILE" ]; then
        tail -40 "$LOG_FILE"
        echo ""
        echo -e "  ${CYAN}1.${RESET} Xóa log  ${CYAN}0.${RESET} Quay lại"
        read -rp "$(echo -e "${WHITE}  Chọn: ${RESET}")" lopt
        [ "$lopt" = "1" ] && > "$LOG_FILE" && echo -e "${GREEN}  [✓] Đã xóa log${RESET}" &&
